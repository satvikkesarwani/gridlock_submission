    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@vitejs/plugin-react": "^5.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.6.0",
    "recharts": "^2.15.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.gridlock.desktop",
    "productName": "GridLock UI",
    "directories": {
